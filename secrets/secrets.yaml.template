# Template for secrets.yaml
# After running setup.sh, copy this to secrets.yaml and encrypt with sops:
#   cp secrets/secrets.yaml.template secrets/secrets.yaml
#   sops -e -i secrets/secrets.yaml
#
# Generate password hash with: mkpasswd -m sha-512

admin:
    password_hash: YOUR_HASHED_PASSWORD_HERE
nextcloud:
    admin_password: YOUR_NEXTCLOUD_ADMIN_PASSWORD_HERE
